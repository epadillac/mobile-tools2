<% content_for(:title) { "Energía" } %>

<div class="min-h-screen bg-gray-100 py-4">
  <div class="max-w-4xl mx-auto px-4">

    <!-- Header card -->
    <div class="bg-white rounded-xl shadow-md p-4 mb-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h1 class="text-lg font-bold text-gray-800">Generación de energía</h1>
          <p class="text-sm text-gray-500"><%= l(Date.current, format: :long) rescue Date.current.to_s %></p>
        </div>
        <%#
          Rendered disabled by default (pointer-events-none + spinner) so it is
          not clickable before Stimulus connects. The refresh-button controller
          enables it once the energy_data frame loads OR errors out, so a
          timeout still leaves the user able to retry.
        %>
        <%= link_to energy_index_path,
              data: {
                turbo_action: "replace",
                controller: "refresh-button",
                refresh_button_frame_value: "energy_data",
                loading: "true",
                action: "click->refresh-button#guard"
              },
              "aria-disabled": "true",
              class: "shrink-0 inline-flex items-center gap-1 px-3 py-2 bg-amber-500 text-white rounded-lg text-sm font-medium hover:bg-amber-600 transition-colors pointer-events-none opacity-60 cursor-not-allowed",
              title: "Actualizar" do %>
          <!-- Idle: refresh icon (hidden until loaded) -->
          <svg data-refresh-button-target="idleIcon" class="hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          <!-- Loading: spinner (shown by default) -->
          <svg data-refresh-button-target="spinnerIcon" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span data-refresh-button-target="label">Cargando…</span>
        <% end %>
      </div>
    </div>

    <%#
      Lazy Turbo Frame: renders skeletons immediately, then fetches the real
      cards from #data and swaps them in once the upstream API responds.
    %>
    <%= turbo_frame_tag "energy_data", src: data_energy_index_path, loading: :lazy do %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <%= render "skeleton_card" %>
        <%= render "skeleton_card" %>
        <%= render "skeleton_card" %>
        <%= render "skeleton_card" %>
      </div>
    <% end %>

  </div>
</div>
