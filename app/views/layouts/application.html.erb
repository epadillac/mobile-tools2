<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Demo" %></title>
    <%# viewport-fit=cover is required for iOS WKWebView to expose
        env(safe-area-inset-*) to CSS. Without it the .native-inset-top
        class from the ruby_native gem evaluates to height:0 and the
        notch/Dynamic-Island area overlaps page content. %>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" data-turbo-track="reload">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" data-turbo-track="reload">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "native", "data-turbo-track": "reload" if hotwire_native_app? %>
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag :ruby_native %>
  </head>

  <body data-controller="theme">
    <%= native_tabs_tag %>
    <% unless current_page?(components_path) %>
      <header class="container mt-3 mb-4">
        <%= link_to components_url, class: "btn btn-outline-secondary", data: { turbo: false } do %>
          <i class="bi bi-arrow-left"></i> Components index
        <% end %>
      </header>
    <% end %>
    <main class="mb-5 <%= 'native-inset-top' if native_app? %>">
      <%= yield %>
    </main>
  </body>
</html>
