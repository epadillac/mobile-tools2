# Template for .env (which is gitignored).
# Copy this file to .env and fill in the real values.
# Never commit .env.

# ---- Receipt parsers ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Telegram notifications ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# ---- Optional split-check basic auth ----
SPLIT_CHECK_PASSWORD=

# ---- ngrok local tunnel (only used by ngrok.sh / start-on-boot.sh) ----
NGROK_AUTHTOKEN=

# ---- Kamal deploy targets ----
# These keep the droplet IP, domain, and registry user out of config/deploy.yml.
# In CI, the same values come from GitHub Actions secrets of the same name.
DROPLET_IP=                     # e.g. 157.230.123.45
DEPLOY_DOMAIN=                  # e.g. app.bambuapps.xyz
KAMAL_REGISTRY_USER=            # your GitHub username for ghcr.io
KAMAL_REGISTRY_PASSWORD=        # GitHub PAT with write:packages, only for laptop deploys
